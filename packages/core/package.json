{
  "name": "@toryo/core",
  "version": "0.1.0",
  "description": "Core engine for the Toryo intelligent agent orchestrator",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JesseRWeigel/toryo.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/JesseRWeigel/toryo/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/JesseRWeigel/toryo/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["ai", "agent", "orchestrator", "llm", "automation", "delegation", "ratchet"],
  "files": ["dist", "README.md"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  }
}
